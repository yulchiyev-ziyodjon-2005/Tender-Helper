# ============================================
# TenderHelper — .gitignore
# Django (Backend) + React/Vite (Frontend)
# ============================================

# ──────────────── Python / Django ────────────────
__pycache__/
*.py[cod]
*$py.class
*.so

# Virtual Environment
venv/
.venv/
env/
ENV/

# Django
*.log
db.sqlite3*
*.sqlite3
*.sqlite3-*
*.sqlite3.*
*.mo
*.pot
media/
staticfiles/
static_collected/

# Migrations (ixtiyoriy — loyihaga qarab)
# backend/*/migrations/

# ──────────────── Node.js / React ────────────────
node_modules/
dist/
build/
.cache/

# Vite
*.local

# ──────────────── Environment & Secrets ────────────────
.env
.env.*
**/.env
**/.env.*
!.env.example
!**/.env.example
secrets/
**/secrets/
*.secret
*.secrets
*.pem
*.key
*.p12
*.pfx
*.jks
service-account*.json
credentials*.json
.envrc
.direnv/
config/local.*
config/secrets.*
backend/migration_backups/
backend/datadump*.json
backend/**/postgresql-*.zip
postgresql-*.zip

# ──────────────── IDE & Editor ────────────────
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db
desktop.ini

# ──────────────── OS Files ────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db

# ──────────────── Testing & Coverage ────────────────
htmlcov/
.tox/
.nox/
.coverage
.coverage.*
.cache
nosetests.xml
coverage.xml
*.cover
*.py,cover
.hypothesis/
.pytest_cache/

# ──────────────── Distribution / Build ────────────────
*.egg-info/
*.egg
dist/
build/
eggs/
wheels/
pip-wheel-metadata/
share/python-wheels/
