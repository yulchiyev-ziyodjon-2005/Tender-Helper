# Tender-Helper AI production environment blueprint
# Copy these keys into VPS systemd, Railway, AWS, or frontend build settings.
# Never commit real secrets.

# Core architecture
APP_ENV=production
DEBUG=False
SECRET_KEY=<generate-a-random-secret-of-at-least-50-characters>
ALLOWED_HOSTS=tenderhelperai.com,api.tenderhelperai.com,127.0.0.1
DATABASE_URL=postgresql://tender_admin:<database-password>@<postgres-private-host>:5432/tender_helper_prod
DATABASE_CONN_MAX_AGE=60
FRONTEND_BASE_URL=https://tenderhelperai.com
CORS_ALLOWED_ORIGINS=https://tenderhelperai.com,https://www.tenderhelperai.com
CSRF_TRUSTED_ORIGINS=https://tenderhelperai.com,https://www.tenderhelperai.com,https://api.tenderhelperai.com

# Django transport and proxy security
SECURE_SSL_REDIRECT=True
SESSION_COOKIE_SECURE=True
CSRF_COOKIE_SECURE=True
SECURE_HSTS_SECONDS=31536000
# Enable these only after every subdomain is permanently HTTPS-ready.
SECURE_HSTS_INCLUDE_SUBDOMAINS=False
SECURE_HSTS_PRELOAD=False
TRUST_X_FORWARDED_PROTO=True

# SMS gateway: Eskiz.uz
SMS_PROVIDER=eskiz
ESKIZ_API_URL=https://notify.eskiz.uz/api
ESKIZ_EMAIL=<eskiz-account-email>
ESKIZ_SECRET_KEY=<eskiz-account-secret-key>
ESKIZ_SMS_FROM=TenderHelper

# Email SMTP: Zoho Mail
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST="smtp.zoho.com"
EMAIL_PORT=465
EMAIL_HOST_USER="info@tenderhelperai.com"
EMAIL_HOST_PASSWORD=<zoho-app-password>
EMAIL_USE_SSL=True
EMAIL_USE_TLS=False
DEFAULT_FROM_EMAIL=Tender-Helper AI <info@tenderhelperai.com>

# Identity platform: Google OAuth
GOOGLE_OAUTH_CLIENT_ID=<google-oauth-web-client-id>
GOOGLE_OAUTH_CLIENT_SECRET=<google-oauth-web-client-secret>

# AI pipelines
GEMINI_API_KEY=<google-gemini-api-key>
GEMINI_MODEL_ANALYSIS=gemini-2.5-flash
GEMINI_MODEL_EMBEDDING=text-embedding-004
GEMINI_TIMEOUT=30
ANALYSIS_PROVIDER=analysis.providers.gemini.GeminiAnalysisProvider

# Async jobs and cache
REDIS_URL=redis://127.0.0.1:6379
CELERY_BROKER_URL=redis://127.0.0.1:6379/0
CELERY_RESULT_BACKEND=redis://127.0.0.1:6379/1
CELERY_TASK_ALWAYS_EAGER=False

# Company registry and document services
COMPANY_REGISTRY_PROVIDER=companies.services.registry.DisabledCompanyRegistryProvider
COMPANY_REGISTRY_API_URL=<approved-registry-api-url>
COMPANY_REGISTRY_API_TOKEN=<approved-registry-api-token>
COMPANY_REGISTRY_SOURCE=tax
COMPANY_REGISTRY_TIMEOUT_SECONDS=5
COMPANY_REGISTRY_RETRY_COUNT=1
COMPANY_REGISTRY_CACHE_SECONDS=86400
COMPANY_REGISTRY_DRAFT_TTL_SECONDS=1800
DOCUMENT_GENERATION_PROVIDER=documents.services.providers.GeminiDocumentGenerationProvider
DOCUMENT_GENERATION_MODEL=gemini-2.5-flash
DOCUMENT_GENERATION_TIMEOUT_SECONDS=30
DOCUMENT_EXPORT_URL_TTL_SECONDS=300
DOCUMENT_PDF_FONT_PATH=

# Authentication, administration, and subscriptions
JWT_ACCESS_TOKEN_LIFETIME_MINUTES=60
JWT_REFRESH_TOKEN_LIFETIME_DAYS=7
ADMIN_MFA_PROVIDER=controlplane.services.mfa.DisabledAdminMFAProvider
ADMIN_MFA_SESSION_SECONDS=43200
ADMIN_STEP_UP_SECONDS=600
COMPETITOR_MIN_SAMPLE_SIZE=3
COMPETITOR_FRESHNESS_SECONDS=86400
COMPETITOR_PERIOD_DAYS=30,90,365

# Payment providers: configure only enabled integrations.
PAYME_MERCHANT_ID=<payme-merchant-id>
PAYME_SECRET_KEY=<payme-secret-key>
CLICK_MERCHANT_ID=<click-merchant-id>
CLICK_SERVICE_ID=<click-service-id>
CLICK_SECRET_KEY=<click-secret-key>
CLICK_ALLOWED_IPS=<click-webhook-ip-1>,<click-webhook-ip-2>
UZUM_MERCHANT_ID=<uzum-merchant-id>
UZUM_SECRET_KEY=<uzum-secret-key>

# Frontend build
VITE_API_BASE_URL=https://api.tenderhelperai.com/api/v1
