# ============================================
# TenderHelper — Environment Variables
# Nusxa oling va .env deb nomlang: cp .env.example .env
# ============================================

# ──────────────── Django Core ────────────────
SECRET_KEY=your-super-secret-key-change-this-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# ──────────────── Database ────────────────
# MVP: SQLite (default) — hech narsa o'zgartirmang
# Production: PostgreSQL ga o'tish uchun quyidagilarni to'ldiring
# DATABASE_URL=postgres://user:password@localhost:5432/tenderhelper

# ──────────────── CORS (Frontend URL) ────────────────
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
FRONTEND_BASE_URL=http://localhost:5173

# ──────────────── JWT Token ────────────────
JWT_ACCESS_TOKEN_LIFETIME_MINUTES=60
JWT_REFRESH_TOKEN_LIFETIME_DAYS=7

# ──────────────── AI (Google Gemini) ────────────────
GEMINI_API_KEY=your-gemini-api-key-from-aistudio-google-com

# ──────────────── SMS OTP (Eskiz.uz) ────────────────
SMS_PROVIDER=console
# SMS_PROVIDER=eskiz
ESKIZ_API_URL=https://notify.eskiz.uz/api
ESKIZ_EMAIL=your-eskiz-email
ESKIZ_PASSWORD=your-eskiz-password

# ──────────────── Google OAuth ────────────────
# Google Cloud Console OAuth Client turi: Web application
# Authorized JavaScript origins:
#   http://localhost:5173
#   http://127.0.0.1:5173
# Authorized redirect URIs:
#   http://localhost:8000/api/v1/auth/google/callback/
#   http://127.0.0.1:8000/api/v1/auth/google/callback/
GOOGLE_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ──────────────── Payment Providers ────────────────
# Payme
PAYME_MERCHANT_ID=your-payme-merchant-id
PAYME_SECRET_KEY=your-payme-secret-key

# Click
CLICK_MERCHANT_ID=your-click-merchant-id
CLICK_SERVICE_ID=your-click-service-id
CLICK_SECRET_KEY=your-click-secret-key

# Uzum
UZUM_MERCHANT_ID=your-uzum-merchant-id
UZUM_SECRET_KEY=your-uzum-secret-key

# ──────────────── Frontend ────────────────
VITE_API_BASE_URL=http://localhost:8000/api/v1
